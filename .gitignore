# ABOUTME: Git ignore for freedom-semantic-shift research project.
# ABOUTME: Excludes secrets, large data, build artifacts, and OS files.

# Secrets
.env
*.env.*
!.env.example

# Runtime batch state (contains transient batch IDs)
outputs/.batch_state_*.json

# Python
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Large data directories (download separately — see README for sources)
/data/
web/data_archive/
web/data_full/
web/data_zenodo_backup/
web/web/

# Node
web/node_modules/

# macOS
.DS_Store
**/.DS_Store
