# ABOUTME: Template for required environment variables.
# ABOUTME: Copy to .env and fill in your own values — never commit .env.

# Anthropic API key — required for LLM-based analysis scripts
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Cloudflare R2 — required only for web/api/labels.js (label persistence)
R2_BUCKET_NAME=your-bucket-name
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_S3_API=https://your-account-id.r2.cloudflarestorage.com/your-bucket
R2_TOKEN_VALUE=your-r2-token
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
